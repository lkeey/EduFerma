{
  "name": "eduferma",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=@eduferma/web",
    "lint": "tsx scripts/lint-project.ts",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "e2e": "playwright test",
    "web:self-review": "tsx scripts/self-review-web-platform.ts",
    "api:openapi:generate": "tsx scripts/api-governance.ts generate",
    "api:openapi:check": "tsx scripts/api-governance.ts check-openapi",
    "api:governance": "tsx scripts/api-governance.ts check",
    "db:generate": "pnpm --filter @eduferma/db db:generate",
    "db:migrate": "pnpm --filter @eduferma/db db:migrate",
    "db:push": "pnpm --filter @eduferma/db db:push",
    "db:seed": "pnpm --filter @eduferma/db db:seed",
    "db:studio": "pnpm --filter @eduferma/db db:studio",
    "db:size:check": "tsx scripts/check-db-size.ts",
    "access:bootstrap": "tsx scripts/bootstrap-account-access.ts",
    "tasks:sync": "tsx scripts/sync-from-local-jsonl.ts",
    "students:sync": "tsx scripts/sync-student-space.ts",
    "seed:demo": "tsx scripts/seed-demo-data.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@playwright/test": "^1.54.1",
    "drizzle-kit": "^0.31.4",
    "dotenv": "^17.4.2",
    "tsx": "^4.20.3",
    "turbo": "^2.10.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
