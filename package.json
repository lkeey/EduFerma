{
  "name": "eduferma",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=@eduferma/web",
    "lint": "tsx scripts/lint-project.ts",
    "typecheck": "turbo typecheck",
    "typecheck:e2e:clerk": "tsc -p tsconfig.clerk-e2e.json --noEmit",
    "typecheck:production:telegram": "tsc -p tsconfig.production-telegram.json --noEmit",
    "test": "vitest run",
    "test:remote-db": "vitest run --config vitest.remote-db.config.ts",
    "e2e": "playwright test",
    "e2e:clerk": "playwright test --config=playwright.clerk.config.ts",
    "e2e:clerk:provision": "tsx scripts/provision-clerk-e2e-users.ts",
    "web:self-review": "tsx scripts/self-review-web-platform.ts",
    "api:openapi:generate": "tsx scripts/api-governance.ts generate",
    "api:openapi:check": "tsx scripts/api-governance.ts check-openapi",
    "api:governance": "tsx scripts/api-governance.ts check",
    "db:generate": "pnpm --filter @eduferma/db db:generate",
    "db:migrate": "pnpm --filter @eduferma/db db:migrate",
    "db:push": "pnpm --filter @eduferma/db db:push",
    "db:seed": "pnpm --filter @eduferma/db db:seed",
    "db:studio": "pnpm --filter @eduferma/db db:studio",
    "db:size:check": "tsx scripts/check-db-size.ts",
    "access:bootstrap": "tsx scripts/bootstrap-account-access.ts",
    "tasks:sync": "tsx scripts/sync-from-local-jsonl.ts",
    "students:sync": "tsx scripts/sync-student-space.ts",
    "production:verify": "tsx scripts/verify-production-setup.ts",
    "production:verify:telegram": "tsx --tsconfig apps/web/tsconfig.json scripts/verify-production-telegram-delivery.ts",
    "seed:demo": "tsx scripts/seed-demo-data.ts"
  },
  "devDependencies": {
    "@clerk/testing": "2.2.9",
    "@neondatabase/serverless": "1.1.0",
    "@playwright/test": "^1.54.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
