{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_SITE_NAME",
    "NEXT_PUBLIC_BRAND_HANDLE",
    "NEXT_PUBLIC_TELEGRAM_URL",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "OWNER_EMAIL",
    "DATABASE_URL",
    "DIRECT_DATABASE_URL",
    "ENABLE_DEMO_AUTH",
    "OPENAPI_DOCS_ENABLED",
    "BLOB_READ_WRITE_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_TELEGRAM_URL",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "CLERK_SECRET_KEY",
        "OWNER_EMAIL",
        "DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "ENABLE_DEMO_AUTH",
        "OPENAPI_DOCS_ENABLED"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
