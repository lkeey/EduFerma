      "@eduferma/api-client": ["packages/api-client/src/index.ts"],
      "@eduferma/api-contract": ["packages/api-contract/src/index.ts"],
      "@eduferma/config": ["packages/config/src/index.ts"],
      "@eduferma/core": ["packages/core/src/index.ts"],
      "@eduferma/core/platform": ["packages/core/src/platform/index.ts"],
      "@eduferma/core/services": ["packages/core/src/services/index.ts"],
      "@eduferma/core/task-sources": ["packages/core/src/task-sources/index.ts"],
      "@eduferma/core/telegram": ["packages/core/src/telegram/index.ts"],
      "@eduferma/db": ["packages/db/src/index.ts"],
      "@eduferma/ui": ["packages/ui/src/index.tsx"],
      "@eduferma/validators": ["packages/validators/src/index.ts"]
